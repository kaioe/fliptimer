{
  "name": "fliptimer",
  "private": true,
  "scripts": {
    "build": "npm run build:css",
    "build:css": "node node_modules/sass/sass.js fliptimer.scss fliptimer.css --style=compressed --source-map",
    "build:dist": "node scripts/build-dist.mjs",
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js -k -n sass,bs -c cyan,magenta \"npm run dev:sass\" \"npm run dev:serve\"",
    "dev:sass": "node node_modules/sass/sass.js --watch --poll fliptimer.scss fliptimer.css --style=expanded --source-map",
    "dev:serve": "node node_modules/browser-sync/dist/bin.js start --config bs-config.js",
    "server": "npm run dev:serve",
    "browser:console": "node scripts/browser-console.mjs",
    "test:preset-save": "node scripts/test-preset-save-no-reload.mjs",
    "test:prep": "node scripts/test-prep-countdown.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:install": "playwright install"
  },
  "devDependencies": {
    "browser-sync": "^3.0.3",
    "concurrently": "^9.1.2",
    "playwright": "^1.58.2",
    "sass": "^1.77.0"
  },
  "dependencies": {
    "jquery": "^3.7.1"
  },
  "optionalDependencies": {
    "@parcel/watcher-darwin-arm64": "2.5.6",
    "@parcel/watcher-darwin-x64": "2.5.6",
    "@parcel/watcher-linux-x64-glibc": "2.5.6",
    "@parcel/watcher-win32-arm64": "2.5.6",
    "@parcel/watcher-win32-x64": "2.5.6"
  }
}
